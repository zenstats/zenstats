# ZenStats Caddy 反向代理配置
# 自动申请和续期 SSL 证书（Let's Encrypt）
#
# 使用方式：
#   设置环境变量 ZENSTATS_DOMAIN=your.domain.com
#   Caddy 会自动为该域名申请 SSL 证书
#
# 本地开发时默认使用 localhost（自签名证书）

{$ZENSTATS_DOMAIN:localhost} {
	# 反向代理到 zenstats 应用
	reverse_proxy zenstats:8080

	# 安全头
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# 请求日志
	log {
		output stdout
		format json
	}

	# 压缩
	encode gzip
}