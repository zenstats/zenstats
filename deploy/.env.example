# ZenStats 部署环境变量配置
# 复制此文件为 .env 并修改对应的值

# ===== 必填 =====

# MaxMind GeoIP License Key（免费注册获取：https://dev.maxmind.com/geoip/geolite2-free-geolocation-data）
ZENSTATS_MAXMIND_LICENSE_KEY=your_license_key_here

# ===== 域名配置 =====

# 你的域名（Caddy 会自动申请 SSL 证书）
# 设置后通过 https://your.domain.com 访问
# 不设置则默认 localhost（使用自签名证书）
ZENSTATS_DOMAIN=stats.example.com

# ===== 可选 =====

# 自定义 JWT 密钥（不设置则使用配置文件中的默认值）
# ZENSTATS_SECRET_KEY=your_custom_secret_key